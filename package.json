{
  "name": "anturun-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:all": "concurrently \"npm run dev:customer\" \"npm run dev:merchant\" \"npm run dev:driver\" \"npm run dev:admin\"",
    "dev:customer": "npm run dev -w @anturun/customer",
    "dev:merchant": "npm run dev -w @anturun/merchant",
    "dev:driver": "npm run dev -w @anturun/driver",
    "dev:admin": "npm run dev -w @anturun/admin",
    "build:all": "concurrently \"npm run build:customer\" \"npm run build:merchant\" \"npm run build:driver\" \"npm run build:admin\"",
    "build:customer": "npm run build -w @anturun/customer",
    "build:merchant": "npm run build -w @anturun/merchant",
    "build:driver": "npm run build -w @anturun/driver",
    "build:admin": "npm run build -w @anturun/admin"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
